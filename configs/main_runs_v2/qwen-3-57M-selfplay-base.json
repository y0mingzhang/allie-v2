{
    "distributed": {"tp_size": 1, "cp_size": 1, "pp_size": 1, "dp_size": 1, "backend": "nccl", "use_cpu": false},
    "model": {"name": "Qwen/Qwen3-1.7B", "use_flash_attention": false, "use_fused_adam": true,
              "vocab_size": 2350, "max_position_embeddings": 1024, "random_init": true,
