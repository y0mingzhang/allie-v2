{
    "distributed": {
        "tp_size": 1,
        "cp_size": 1,
        "pp_size": 1,
        "dp_size": 8,
        "backend": "nccl",
        "use_cpu": false
    },
    "model": {
        "name": "Qwen/Qwen3-1.7B",
        "use_flash_attention": false,
        "use_fused_adam": true,
        "vocab_size": 2350,
        "max_position_embeddings": 1024
    },
    "training": {
        "seed": 42,
        "total_train_steps": 10000,
        "seq_length": 1024,
        "micro_batch_size": 56,
        "gradient_accumulation_steps": 1,
        "max_tokens": null,
        "grad_clip_norm": 1.0,
        "torch_compile": true,
        "optimizer": {
            "name": "muon",
            "weight_decay": 0.05,
            "momentum": 0.9,
            "ns_coefficients": [3.4445, -4.775, 2.0315],
            "ns_steps": 5,
            "adjust_lr_fn": "match_rms_adamw",
            "muon_eps": 1e-7
        },
        "lr_schedule": {
            "type": "warmup_stable_decay",
            "warmup_steps": 200,
            "stable_steps": 8000,
            "decay_steps": 1800,
            "max_lr": 1e-2,
            "min_lr": 1e-4
        }
    },
    "dataset": {
        "name": "tokens",
        "train_glob": "data/tokens_v2/derisk_r3/train.npy",
        "val_glob": "data/tokens_v2/derisk_r3/val.npy",
        "num_workers": 4
    },
    "validation": {
        "every_steps": 200,
        "num_samples": 2048
    },
    "checkpoint": {
        "save_dir": "models/main_runs_v2/qwen-3-1.7b-continue-v3",
        "save_frequency": 1000,
        "load_path": ""
    },
    "logging": {
        "use_wandb": true,
        "project_name": "chess-v3-derisk",
        "run_name": "qwen-3-1.7b-continue-v3"
    },
    "environment": {
        "OMP_NUM_THREADS": "2",
        "TOKENIZERS_PARALLELISM": "false",
        "FLASH_ATTEN": "0"
    }
}
